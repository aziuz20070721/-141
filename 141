
<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Календарь · ТФ-25-141</title>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #12121a;
    --surface2: #1a1a26;
    --border: #252535;
    --accent-exam: #ff4d6d;
    --accent-consult: #4cc9f0;
    --accent-zachet: #7bed9f;
    --accent-retake: #ffd60a;
    --accent-custom: #c77dff;
    --text: #e8e8f0;
    --muted: #6b6b85;
    --today: #2a1a3e;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(76,201,240,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(76,201,240,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }
  header {
    padding: 2rem 2rem 1.2rem;
    display: flex;
    align-items: flex-end;
    gap: 1.2rem;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(76,201,240,0.06) 0%, transparent 100%);
  }
  .group-badge {
    font-family: 'Unbounded', sans-serif;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--accent-consult);
    background: rgba(76,201,240,0.1);
    border: 1px solid rgba(76,201,240,0.3);
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
  }
  h1 {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(1.2rem, 3.5vw, 2rem);
    font-weight: 300;
    letter-spacing: -0.02em;
  }
  h1 span { font-weight: 700; color: var(--accent-consult); }
  .semester-label {
    font-size: 0.78rem;
    color: var(--muted);
    margin-left: auto;
    align-self: center;
  }
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.2rem;
    padding: 0.8rem 2rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    align-items: center;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.75rem;
    color: var(--muted);
  }
  .legend-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }

  /* upcoming strip */
  .upcoming-strip {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 0.9rem 2rem;
    display: flex;
    gap: 0.65rem;
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
    align-items: center;
  }
  .strip-label {
    flex-shrink: 0;
    writing-mode: vertical-lr;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
  }
  .upcoming-card {
    flex-shrink: 0;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem 0.9rem;
    min-width: 148px;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .upcoming-card:hover { border-color: rgba(255,255,255,0.2); }
  .upcoming-card.exam    { border-top: 2px solid var(--accent-exam); }
  .upcoming-card.consult { border-top: 2px solid var(--accent-consult); }
  .upcoming-card.zachet  { border-top: 2px solid var(--accent-zachet); }
  .upcoming-card.retake  { border-top: 2px solid var(--accent-retake); }
  .upcoming-card.custom  { border-top: 2px solid var(--accent-custom); }
  .uc-date { font-size: 0.63rem; color: var(--muted); margin-bottom: 0.2rem; }
  .uc-subject { font-size: 0.8rem; font-weight: 500; color: var(--text); margin-bottom: 0.12rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 140px; }
  .uc-type { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; }
  .exam .uc-type    { color: var(--accent-exam); }
  .consult .uc-type { color: var(--accent-consult); }
  .zachet .uc-type  { color: var(--accent-zachet); }
  .retake .uc-type  { color: var(--accent-retake); }
  .custom .uc-type  { color: var(--accent-custom); }

  /* calendar */
  .months-container {
    padding: 1.5rem 2rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .month-title {
    font-family: 'Unbounded', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .month-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .day-header {
    text-align: center;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--muted);
    padding: 0.35rem 0;
    text-transform: uppercase;
  }
  .day-cell {
    min-height: 68px;
    padding: 0.4rem;
    border-radius: 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: transform 0.13s, border-color 0.13s, background 0.13s;
    position: relative;
    overflow: hidden;
  }
  .day-cell.empty { background: transparent; border-color: transparent; cursor: default; pointer-events: none; }
  .day-cell:not(.empty):hover { transform: scale(1.03); border-color: rgba(255,255,255,0.15); z-index: 5; }
  .day-cell.today { background: var(--today); border-color: rgba(123,80,200,0.5); }
  .day-num { font-size: 0.78rem; font-weight: 500; color: var(--muted); margin-bottom: 0.28rem; }
  .day-cell.today .day-num { color: #b08fff; font-weight: 700; }
  .event-pills { display: flex; flex-direction: column; gap: 2px; }
  .pill {
    font-size: 0.56rem;
    font-weight: 500;
    padding: 2px 5px;
    border-radius: 3px;
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pill.exam    { background: rgba(255,77,109,0.22);  color: var(--accent-exam);    border-left: 2px solid var(--accent-exam); }
  .pill.consult { background: rgba(76,201,240,0.16);  color: var(--accent-consult); border-left: 2px solid var(--accent-consult); }
  .pill.zachet  { background: rgba(123,237,159,0.16); color: var(--accent-zachet);  border-left: 2px solid var(--accent-zachet); }
  .pill.retake  { background: rgba(255,214,10,0.16);  color: var(--accent-retake);  border-left: 2px solid var(--accent-retake); }
  .pill.custom  { background: rgba(199,125,255,0.18); color: var(--accent-custom);  border-left: 2px solid var(--accent-custom); }

  /* add-event hint on empty hover */
  .day-cell:not(.empty):not(.has-event):hover .add-hint { opacity: 1; }
  .add-hint {
    opacity: 0;
    transition: opacity 0.15s;
    font-size: 0.58rem;
    color: var(--muted);
    margin-top: 0.2rem;
  }

  /* ===== MODAL ===== */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.72);
    backdrop-filter: blur(5px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.4rem;
    max-width: 440px;
    width: calc(100% - 2rem);
    transform: translateY(12px);
    transition: transform 0.2s;
    max-height: 90vh;
    overflow-y: auto;
  }
  .modal-overlay.open .modal { transform: translateY(0); }
  .modal-date {
    font-family: 'Unbounded', sans-serif;
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.14em;
    margin-bottom: 0.9rem;
  }
  .modal-event {
    padding: 0.7rem 0.9rem;
    border-radius: 8px;
    margin-bottom: 0.45rem;
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    position: relative;
  }
  .modal-event.exam    { background: rgba(255,77,109,0.1);   border: 1px solid rgba(255,77,109,0.28); }
  .modal-event.consult { background: rgba(76,201,240,0.08);  border: 1px solid rgba(76,201,240,0.28); }
  .modal-event.zachet  { background: rgba(123,237,159,0.08); border: 1px solid rgba(123,237,159,0.28); }
  .modal-event.retake  { background: rgba(255,214,10,0.08);  border: 1px solid rgba(255,214,10,0.28); }
  .modal-event.custom  { background: rgba(199,125,255,0.1);  border: 1px solid rgba(199,125,255,0.28); }
  .modal-event-type { font-size: 0.62rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; }
  .exam .modal-event-type    { color: var(--accent-exam); }
  .consult .modal-event-type { color: var(--accent-consult); }
  .zachet .modal-event-type  { color: var(--accent-zachet); }
  .retake .modal-event-type  { color: var(--accent-retake); }
  .custom .modal-event-type  { color: var(--accent-custom); }
  .modal-event-name { font-size: 0.88rem; font-weight: 500; color: var(--text); }
  .modal-event-detail { font-size: 0.73rem; color: var(--muted); }
  .delete-btn {
    position: absolute;
    top: 0.5rem; right: 0.5rem;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 0.9rem;
    cursor: pointer;
    padding: 0 0.25rem;
    line-height: 1;
    transition: color 0.15s;
  }
  .delete-btn:hover { color: var(--accent-exam); }

  /* add event form inside modal */
  .add-form {
    margin-top: 0.8rem;
    border-top: 1px solid var(--border);
    padding-top: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .add-form-title {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.15rem;
  }
  .add-form input, .add-form textarea, .add-form select {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 7px;
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    padding: 0.5rem 0.75rem;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
    resize: none;
  }
  .add-form input:focus, .add-form textarea:focus, .add-form select:focus {
    border-color: rgba(199,125,255,0.5);
  }
  .add-form select option { background: #1a1a26; }
  .btn-row { display: flex; gap: 0.5rem; margin-top: 0.2rem; }
  .btn-add {
    flex: 1;
    background: rgba(199,125,255,0.18);
    border: 1px solid rgba(199,125,255,0.4);
    color: var(--accent-custom);
    border-radius: 7px;
    padding: 0.55rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-add:hover { background: rgba(199,125,255,0.28); }
  .modal-close {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.55rem;
    color: var(--muted);
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    margin-top: 0.6rem;
  }
  .modal-close:hover { background: var(--border); color: var(--text); }

  @media (max-width: 600px) {
    header { padding: 1.2rem 1rem 1rem; }
    .months-container { padding: 1rem 0.6rem 3rem; }
    .legend { padding: 0.6rem 1rem; }
    .upcoming-strip { padding: 0.7rem 0.8rem; }
    .day-cell { min-height: 54px; padding: 0.3rem; }
  }
</style>
</head>
<body>

<header>
  <div><div class="group-badge">ТФ-25-141</div></div>
  <h1>Сессия <span>2025–2026</span></h1>
  <div class="semester-label">Весенний семестр</div>
</header>

<div class="upcoming-strip" id="upcomingStrip">
  <div class="strip-label">Ближайшее</div>
</div>

<div class="legend">
  <div class="legend-item"><div class="legend-dot" style="background:var(--accent-zachet)"></div> Зачёт</div>
  <div class="legend-item"><div class="legend-dot" style="background:var(--accent-consult)"></div> Консультация</div>
  <div class="legend-item"><div class="legend-dot" style="background:var(--accent-exam)"></div> Экзамен</div>
  <div class="legend-item"><div class="legend-dot" style="background:var(--accent-retake)"></div> Пересдача</div>
  <div class="legend-item"><div class="legend-dot" style="background:var(--accent-custom)"></div> Своё событие</div>
  <div class="legend-item" style="margin-left:auto; font-size:0.72rem; color:var(--muted)">Клик по дню → добавить событие</div>
</div>

<div class="months-container" id="monthsContainer"></div>

<!-- MODAL -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal" id="modal">
    <div class="modal-date" id="modalDate"></div>
    <div id="modalEvents"></div>
    <div class="add-form" id="addForm">
      <div class="add-form-title">+ Добавить событие</div>
      <input type="text" id="newSubject" placeholder="Название события" maxlength="80">
      <select id="newType">
        <option value="custom">Своё событие</option>
        <option value="exam">Экзамен</option>
        <option value="consult">Консультация</option>
        <option value="zachet">Зачёт</option>
        <option value="retake">Пересдача</option>
      </select>
      <textarea id="newNote" rows="2" placeholder="Заметка (необязательно)"></textarea>
      <div class="btn-row">
        <button class="btn-add" id="btnAddEvent">Добавить</button>
      </div>
    </div>
    <button class="modal-close" id="btnClose">Закрыть</button>
  </div>
</div>

<script>
const TODAY = '2026-06-01';

const TYPE_LABELS = { exam: 'ЭКЗАМЕН', consult: 'КОНСУЛЬТАЦИЯ', zachet: 'ЗАЧЁТ', retake: 'ПЕРЕСДАЧА', custom: 'МОЁ СОБЫТИЕ' };

// ---- BUILT-IN EVENTS ----
const builtinEvents = [
  { date: '2026-06-01', type: 'zachet',  subject: 'Иностранный язык (русский)', note: 'Зачёт · 09:00 · ауд. 104 · Тошматова Т.Т., Яремчук О.В.' },
  { date: '2026-06-03', type: 'zachet',  subject: 'Рус. яз. / Психол. и пед.',  note: 'Зачёт · 10:00 · ауд. 102 · Тошматова Т.Т., Узакова З.Ф.' },
  { date: '2026-06-04', type: 'zachet',  subject: 'Начертательная геометрия',   note: 'Зачёт · 12:00 · ауд. 212 · Куваева Н.И.' },
  { date: '2026-06-04', type: 'retake',  subject: 'Общая физика',                note: 'Пересдача · оценка «2»' },
  { date: '2026-06-05', type: 'zachet',  subject: 'Физическая культура',         note: 'Зачёт · 09:00 · сп. зал · Сияев С.Р.' },
  { date: '2026-06-06', type: 'zachet',  subject: 'История России',              note: 'Зачёт с оценкой · 12:00 · ауд. 102 · Алимджанов Б.А.' },
  { date: '2026-06-08', type: 'consult', subject: 'Информатика',                 note: 'Аттестация разделов, консультация · 09:00 · ауд. 102 · Егамбердиев Б.Б.' },
  { date: '2026-06-09', type: 'exam',    subject: 'Информатика (устный опрос)',  note: '09:00 · ауд. 210/212 · Егамбердиев Б.Б., Киселёв Б.Г.' },
  { date: '2026-06-10', type: 'exam',    subject: 'Информатика',                 note: 'Экзамен · 09:00 · ауд. 210/212 · Егамбердиев Б.Б., Киселёв Б.Г.' },
  { date: '2026-06-11', type: 'consult', subject: 'Математический анализ',       note: 'Аттестация разделов, консультация · 09:00 · ауд. 102' },
  { date: '2026-06-13', type: 'exam',    subject: 'Математический анализ',       note: 'Экзамен · 09:00 · ауд. 102 · Бухарова Т.И., Рахматуллаев А.М.' },
  { date: '2026-06-15', type: 'consult', subject: 'Линейная алгебра',            note: 'Аттестация разделов, консультация · 09:00 · ауд. 102 · Шарипов А.А.' },
  { date: '2026-06-17', type: 'exam',    subject: 'Линейная алгебра',            note: 'Экзамен · 09:00 · ауд. 102 · Бухарова Т.И., Шарипов А.А.' },
  { date: '2026-06-20', type: 'consult', subject: 'Общая физика (молек. физика)', note: 'Аттестация разделов, консультация · 09:00 · ауд. 102' },
  { date: '2026-06-22', type: 'exam',    subject: 'Общая физика (молек. физика)', note: 'Экзамен · 09:00 · ауд. 102 · Загайнов В.А., Хугаев А.В. и др.' },
  { date: '2026-06-24', type: 'consult', subject: 'Химия',                       note: 'Аттестация разделов, консультация · 09:00 · ауд. 102' },
  { date: '2026-06-26', type: 'exam',    subject: 'Химия',                       note: 'Экзамен · 09:00 · ауд. 102 · Щербина Н.А., Конюхов В.Ю. и др.' },
  { date: '2026-06-29', type: 'retake',  subject: 'Химия (пересдача)',           note: 'Пересдача · 09:00 · ауд. 102 · Щербина Н.А. и др.' },
];
builtinEvents.forEach(e => { e.builtin = true; e.id = 'b_' + Math.random().toString(36).slice(2); });

// ---- USER EVENTS (localStorage) ----
function loadUserEvents() {
  try { return JSON.parse(localStorage.getItem('cal141_events') || '[]'); } catch { return []; }
}
function saveUserEvents(arr) {
  localStorage.setItem('cal141_events', JSON.stringify(arr));
}
let userEvents = loadUserEvents();

function allEvents() { return [...builtinEvents, ...userEvents]; }

function buildEventMap() {
  const m = {};
  allEvents().forEach(ev => {
    if (!m[ev.date]) m[ev.date] = [];
    m[ev.date].push(ev);
  });
  return m;
}

// ---- MONTHS ----
const MONTHS = [
  { year: 2026, month: 6,  label: 'ИЮНЬ 2026' },
  { year: 2026, month: 7,  label: 'ИЮЛЬ 2026' },
];
const DAY_HEADERS = ['ПН','ВТ','СР','ЧТ','ПТ','СБ','ВС'];

// ---- RENDER ----
function render() {
  const eventMap = buildEventMap();

  // upcoming strip
  const strip = document.getElementById('upcomingStrip');
  // keep label
  strip.innerHTML = '<div class="strip-label">Ближайшее</div>';
  const upcoming = allEvents()
    .filter(e => e.date >= TODAY)
    .sort((a,b) => a.date.localeCompare(b.date))
    .slice(0, 12);
  upcoming.forEach(ev => {
    const d = new Date(ev.date + 'T00:00:00');
    const ds = d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });
    const card = document.createElement('div');
    card.className = `upcoming-card ${ev.type}`;
    card.innerHTML = `<div class="uc-date">${ds}</div><div class="uc-subject">${ev.subject}</div><div class="uc-type">${TYPE_LABELS[ev.type]||ev.type}</div>`;
    card.onclick = () => openModal(ev.date);
    strip.appendChild(card);
  });

  // calendar months
  const container = document.getElementById('monthsContainer');
  container.innerHTML = '';

  MONTHS.forEach(({ year, month, label }) => {
    const block = document.createElement('div');
    block.className = 'month-block';

    const title = document.createElement('div');
    title.className = 'month-title';
    title.textContent = label;
    block.appendChild(title);

    const grid = document.createElement('div');
    grid.className = 'calendar-grid';

    DAY_HEADERS.forEach(h => {
      const hd = document.createElement('div');
      hd.className = 'day-header';
      hd.textContent = h;
      grid.appendChild(hd);
    });

    const firstDay = new Date(year, month - 1, 1).getDay();
    const offset = (firstDay + 6) % 7;
    const daysInMonth = new Date(year, month, 0).getDate();

    for (let i = 0; i < offset; i++) {
      const e = document.createElement('div');
      e.className = 'day-cell empty';
      grid.appendChild(e);
    }

    for (let d = 1; d <= daysInMonth; d++) {
      const dateStr = `${year}-${String(month).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const cell = document.createElement('div');
      cell.className = 'day-cell';
      if (dateStr === TODAY) cell.classList.add('today');

      const dayEvs = eventMap[dateStr];
      if (dayEvs && dayEvs.length) cell.classList.add('has-event');

      const numEl = document.createElement('div');
      numEl.className = 'day-num';
      numEl.textContent = d;
      cell.appendChild(numEl);

      const pills = document.createElement('div');
      pills.className = 'event-pills';
      if (dayEvs) {
        dayEvs.forEach(ev => {
          const pill = document.createElement('div');
          pill.className = `pill ${ev.type}`;
          pill.textContent = ev.subject;
          pills.appendChild(pill);
        });
      }
      cell.appendChild(pills);

      const hint = document.createElement('div');
      hint.className = 'add-hint';
      hint.textContent = '+ добавить';
      cell.appendChild(hint);

      cell.onclick = () => openModal(dateStr);
      grid.appendChild(cell);
    }

    block.appendChild(grid);
    container.appendChild(block);
  });
}

// ---- MODAL ----
let currentDate = null;

function openModal(dateStr) {
  currentDate = dateStr;
  const eventMap = buildEventMap();
  const dayEvs = eventMap[dateStr] || [];

  const d = new Date(dateStr + 'T00:00:00');
  document.getElementById('modalDate').textContent =
    d.toLocaleDateString('ru-RU', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }).toUpperCase();

  const evContainer = document.getElementById('modalEvents');
  evContainer.innerHTML = '';

  dayEvs.forEach(ev => {
    const div = document.createElement('div');
    div.className = `modal-event ${ev.type}`;
    div.innerHTML = `
      <div class="modal-event-type">${TYPE_LABELS[ev.type] || ev.type}</div>
      <div class="modal-event-name">${ev.subject}</div>
      <div class="modal-event-detail">${ev.note || ''}</div>
    `;
    if (!ev.builtin) {
      const btn = document.createElement('button');
      btn.className = 'delete-btn';
      btn.title = 'Удалить';
      btn.textContent = '✕';
      btn.onclick = (e) => { e.stopPropagation(); deleteEvent(ev.id); };
      div.appendChild(btn);
    }
    evContainer.appendChild(div);
  });

  // reset form
  document.getElementById('newSubject').value = '';
  document.getElementById('newNote').value = '';
  document.getElementById('newType').value = 'custom';

  document.getElementById('modalOverlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  currentDate = null;
}

function deleteEvent(id) {
  userEvents = userEvents.filter(e => e.id !== id);
  saveUserEvents(userEvents);
  render();
  openModal(currentDate);
}

document.getElementById('btnClose').onclick = closeModal;
document.getElementById('modalOverlay').onclick = (e) => {
  if (e.target === document.getElementById('modalOverlay')) closeModal();
};

document.getElementById('btnAddEvent').onclick = () => {
  const subject = document.getElementById('newSubject').value.trim();
  if (!subject) { document.getElementById('newSubject').focus(); return; }
  const type = document.getElementById('newType').value;
  const note = document.getElementById('newNote').value.trim();
  const newEv = {
    id: 'u_' + Date.now(),
    date: currentDate,
    type,
    subject,
    note,
    builtin: false,
  };
  userEvents.push(newEv);
  saveUserEvents(userEvents);
  render();
  openModal(currentDate);
};

// initial render
render();
</script>
